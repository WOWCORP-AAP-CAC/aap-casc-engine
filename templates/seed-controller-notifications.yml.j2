---
# Example notifications configuration — rename to .yml to activate.
# This file belongs in base/notifications/ and applies to ALL environments.
# For environment-specific overrides, place a .yml file in <env>/notifications/.
controller_notifications:
  - name: ntf-{{ org_id }}-example-email
    description: "Example email notification — replace with your integration"
    organization: org-{{ org_id }}
    notification_type: email
    notification_configuration:
      host: smtp.example.com
      port: 587
      username: notifications@example.com
      sender: aap-notifications@example.com
      recipients:
        - "team-{{ org_id }}@example.com"
      use_tls: true
      use_ssl: false
