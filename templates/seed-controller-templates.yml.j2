---
# Example job templates configuration — rename to .yml to activate.
# This file belongs in base/templates/ and applies to ALL environments.
# For environment-specific overrides, place a .yml file in <env>/templates/.
controller_templates:
  - name: jt-{{ tenant_id }}-example
    description: "Example job template — replace with your automation use-case"
    organization: {{ _effective_aap_organization | to_json }}
    project: prj-{{ tenant_id }}-example
    playbook: site.yml
    inventory: inv-{{ tenant_id }}-src-dev-example
    credentials:
      - crd-{{ tenant_id }}-mch-example
    ask_variables_on_launch: false
    verbosity: 0
