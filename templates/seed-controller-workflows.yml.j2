---
# Example workflows configuration — rename to .yml to activate.
# This file belongs in base/workflows/ and applies to ALL environments.
# For environment-specific overrides, place a .yml file in <env>/workflows/.
controller_workflows:
  - name: wfjt-{{ tenant_id }}-example
    description: "Example workflow — replace with your orchestration use-case"
    organization: {{ _effective_aap_organization | to_json }}
    simplified_workflow_nodes:
      - identifier: node-start
        unified_job_template: jt-{{ tenant_id }}-example
        success_nodes: []
        failure_nodes: []
        always_nodes: []
    ask_variables_on_launch: false
