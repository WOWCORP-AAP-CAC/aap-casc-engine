#jinja2: trim_blocks: False
{# Ansible-specific pragma — vanilla Jinja2 with trim_blocks=True will still collapse lines. #}
name: CasC Pipeline
on:
  push:
  pull_request:
    branches: [main]
  workflow_dispatch:
jobs:
  casc:
    uses: {{ platform_scm_org }}/{{ engine_repo | default('aap-casc-engine') }}/.github/workflows/casc-validate-and-trigger.yml@{{ engine_ref | default('main', true) }}
    with:
      dispatcher_jt_name: jt-platform-casc_dispatcher
      platform_scm_org: {{ platform_scm_org }}
      platform_home_repo: {{ platform_repo | default('casc-platform-global') }}
      platform_branch: {{ platform_branch | default('main') }}
    secrets:
      AAP_ENGINE_HOST: {% raw %}${{ secrets.AAP_ENGINE_HOST }}{% endraw %}
      AAP_ENGINE_TOKEN: {% raw %}${{ secrets.AAP_ENGINE_TOKEN }}{% endraw %}
      AAP_ENGINE_USERNAME: {% raw %}${{ secrets.AAP_ENGINE_USERNAME }}{% endraw %}
      AAP_ENGINE_PASSWORD: {% raw %}${{ secrets.AAP_ENGINE_PASSWORD }}{% endraw %}
      AAP_ENV_TARGETS_JSON: {% raw %}${{ secrets.AAP_ENV_TARGETS_JSON }}{% endraw %}
      AAP_FANOUT_ALLOW_BASIC: {% raw %}${{ secrets.AAP_FANOUT_ALLOW_BASIC }}{% endraw %}
      AAP_HOST: {% raw %}${{ secrets.AAP_HOST }}{% endraw %}
      AAP_USERNAME: {% raw %}${{ secrets.AAP_USERNAME }}{% endraw %}
      AAP_PASSWORD: {% raw %}${{ secrets.AAP_PASSWORD }}{% endraw %}
      ENGINE_REPO_TOKEN: {% raw %}${{ secrets.ENGINE_REPO_TOKEN }}{% endraw %}
      PLATFORM_REPO_TOKEN: {% raw %}${{ secrets.PLATFORM_REPO_TOKEN }}{% endraw %}
