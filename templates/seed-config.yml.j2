#jinja2: trim_blocks: False
---
scm_provider: {{ scm_provider | to_json }}
control_scm_org: {{ control_scm_org | to_json }}
control_repo: {{ control_repo | to_json }}
control_branch: {{ control_branch | to_json }}
platform_scm_org: {{ platform_scm_org | to_json }}
platform_repo: {{ (platform_repo | default('casc-platform-global')) | to_json }}
create_missing_env_branches: {{ create_missing_env_branches | default(true) | bool | lower }}
bootstrap_dispatch_fanout: {{ bootstrap_dispatch_fanout | default(true) | bool | lower }}
dispatcher_concurrency: serialized

job_templates:
  genesis: {{ (genesis_jt_name | default('jt-platform-genesis', true)) | to_json }}
  bootstrap: {{ (bootstrap_jt_name | default('jt-platform-bootstrap_tenant', true)) | to_json }}
  dispatcher: {{ (dispatcher_jt_name | default('jt-platform-casc_dispatcher', true)) | to_json }}
  drift_detection: {{ (drift_detection_jt_name | default('jt-platform-drift_detection', true)) | to_json }}

env_branch_map:
{{ _effective_env_branch_map | to_nice_yaml(indent=2) | indent(2, true) }}
