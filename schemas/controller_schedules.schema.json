{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "AAP Controller Schedules Configuration",
    "type": "object",
    "properties": {
        "controller_schedules": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["name", "unified_job_template"],
                "properties": {
                    "name": {
                        "type": "string",
                        "pattern": "^sch-[a-z0-9_]+(-[a-z0-9_]+)*$",
                        "description": "Schedule name following naming convention: sch-<org_id>-<purpose>"
                    },
                    "description": { "type": "string" },
                    "unified_job_template": { "type": "string" },
                    "organization": {
                        "type": "string",
                        "pattern": "^org-[a-z0-9_]+$"
                    },
                    "rrule": {
                        "type": "string",
                        "description": "RFC 5545 recurrence rule"
                    },
                    "enabled": { "type": "boolean" },
                    "extra_data": {
                        "type": "object",
                        "description": "Extra variables passed to the job template at schedule run time"
                    }
                },
                "additionalProperties": false
            }
        }
    },
    "required": ["controller_schedules"],
    "additionalProperties": false
}
