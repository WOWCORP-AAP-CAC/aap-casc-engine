{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "AAP Controller Settings Configuration",
    "description": "Controller settings are AAP-internal settings (e.g., AWX_TASK_ENV, AWX_ISOLATION_SHOW_PATHS). Setting names are defined by AAP, not user-defined.",
    "type": "object",
    "properties": {
        "controller_settings": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["name", "value"],
                "properties": {
                    "name": {
                        "type": "string",
                        "description": "AAP setting name (e.g., AWX_TASK_ENV, DEFAULT_EXECUTION_ENVIRONMENT)"
                    },
                    "value": {
                        "description": "Setting value (type varies per setting — string, object, integer, boolean)"
                    }
                },
                "additionalProperties": false
            }
        }
    },
    "required": ["controller_settings"],
    "additionalProperties": false
}
