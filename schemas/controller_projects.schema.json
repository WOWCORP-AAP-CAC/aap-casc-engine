{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "AAP Controller Projects Configuration",
    "type": "object",
    "properties": {
        "controller_projects": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["name", "organization", "scm_type"],
                "properties": {
                    "name": {
                        "type": "string",
                        "pattern": "^prj-pbk-[a-z0-9_]+-[a-z0-9_]+(-[a-z0-9_]+)*$",
                        "description": "Project name following naming convention"
                    },
                    "description": { "type": "string" },
                    "organization": {
                        "type": "string",
                        "pattern": "^org-[a-z0-9_]+$"
                    },
                    "scm_type": {
                        "type": "string",
                        "enum": ["archive", "git", "svn", "insights"]
                    },
                    "scm_url": { "type": "string", "format": "uri" },
                    "scm_branch": { "type": "string" },
                    "default_environment": { "type": "string" },
                    "scm_clean": { "type": "boolean" },
                    "scm_delete_on_update": { "type": "boolean" },
                    "scm_update_on_launch": { "type": "boolean" }
                },
                "additionalProperties": false
            }
        }
    },
    "required": ["controller_projects"],
    "additionalProperties": false
}
