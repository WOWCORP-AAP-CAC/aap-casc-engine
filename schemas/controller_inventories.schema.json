{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "AAP Controller Inventories Configuration",
    "type": "object",
    "properties": {
        "controller_inventories": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["name", "organization"],
                "properties": {
                    "name": {
                        "type": "string",
                        "pattern": "^inv-[a-z0-9_]+(-[a-z0-9_]+)+$",
                        "description": "Inventory name following naming convention: inv-<org_id>-<env> or inv-<org_id>-<source>-<env>-<name>"
                    },
                    "description": { "type": "string" },
                    "organization": {
                        "type": "string",
                        "pattern": "^org-[a-z0-9_]+$"
                    },
                    "kind": {
                        "type": "string",
                        "enum": ["", "smart", "constructed"],
                        "default": ""
                    },
                    "prevent_instance_group_fallback": { "type": "boolean" },
                    "inventory_sources": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "required": ["name", "source"],
                            "properties": {
                                "name": { "type": "string" },
                                "description": { "type": "string" },
                                "source": {
                                    "type": "string",
                                    "enum": ["scm", "ec2", "gce", "azure_rm", "vmware", "satellite6", "openstack", "rhv", "controller", "insights"]
                                },
                                "source_path": { "type": "string" },
                                "execution_environment": { "type": "string" },
                                "source_project": { "type": "string" },
                                "credential": { "type": "string" },
                                "overwrite": { "type": "boolean" },
                                "overwrite_vars": { "type": "boolean" },
                                "update_on_launch": { "type": "boolean" },
                                "update_cache_timeout": { "type": "integer" }
                            }
                        }
                    }
                },
                "additionalProperties": false
            }
        }
    },
    "required": ["controller_inventories"],
    "additionalProperties": false
}
