{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "AAP Controller Credentials Configuration",
    "type": "object",
    "properties": {
        "controller_credentials": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["name", "organization", "credential_type"],
                "properties": {
                    "name": {
                        "type": "string",
                        "pattern": "^crd-[a-z0-9_]+(-[a-z0-9_]+)+$",
                        "description": "Credential name following naming convention: crd-<org_id>-<purpose>"
                    },
                    "description": { "type": "string" },
                    "organization": {
                        "type": "string",
                        "pattern": "^org-[a-z0-9_]+$"
                    },
                    "credential_type": {
                        "type": "string",
                        "description": "Name of the credential type (e.g., ctp-database_credentials)"
                    },
                    "inputs": {
                        "type": "object",
                        "description": "Static input fields for the credential"
                    },
                    "input_sources": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "required": ["input_field_name", "source_credential", "target_credential"],
                            "properties": {
                                "input_field_name": { "type": "string" },
                                "metadata": {
                                    "type": "object",
                                    "properties": {
                                        "secret_key": { "type": "string" },
                                        "secret_path": { "type": "string" }
                                    }
                                },
                                "source_credential": { "type": "string" },
                                "target_credential": { "type": "string" }
                            }
                        }
                    }
                },
                "additionalProperties": false
            }
        }
    },
    "required": ["controller_credentials"],
    "additionalProperties": false
}
