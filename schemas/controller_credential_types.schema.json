{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "AAP Controller Credential Types Configuration",
    "type": "object",
    "properties": {
        "controller_credential_types": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["name", "kind"],
                "properties": {
                    "name": {
                        "type": "string",
                        "pattern": "^ctp-[a-z0-9_]+$",
                        "description": "Credential type name following naming convention: ctp-<purpose>"
                    },
                    "description": { "type": "string" },
                    "kind": {
                        "type": "string",
                        "enum": ["cloud", "net"]
                    },
                    "inputs": {
                        "type": "object",
                        "properties": {
                            "fields": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "required": ["id", "label", "type"],
                                    "properties": {
                                        "id": { "type": "string" },
                                        "label": { "type": "string" },
                                        "type": { "type": "string", "enum": ["string", "boolean", "number"] },
                                        "secret": { "type": "boolean" },
                                        "help_text": { "type": "string" }
                                    }
                                }
                            },
                            "required": {
                                "type": "array",
                                "items": { "type": "string" }
                            }
                        }
                    },
                    "injectors": {
                        "type": "object",
                        "properties": {
                            "extra_vars": { "type": "object" },
                            "env": { "type": "object" },
                            "file": { "type": "object" }
                        }
                    }
                },
                "additionalProperties": false
            }
        }
    },
    "required": ["controller_credential_types"],
    "additionalProperties": false
}
