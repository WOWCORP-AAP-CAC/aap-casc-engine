{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "AAP Controller Workflow Job Templates Configuration",
    "type": "object",
    "properties": {
        "controller_workflows": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["name", "organization"],
                "properties": {
                    "name": {
                        "type": "string",
                        "pattern": "^wfjt-[a-z0-9_]+-[a-z0-9_]+(-[a-z]+)?$",
                        "description": "Workflow job template name following naming convention: wfjt-<org_id>-<use_case>"
                    },
                    "description": { "type": "string" },
                    "organization": {
                        "type": "string",
                        "pattern": "^org-[a-z0-9_]+$"
                    },
                    "inventory": { "type": "string" },
                    "limit": { "type": "string" },
                    "extra_vars": {
                        "oneOf": [
                            { "type": "object" },
                            { "type": "string" }
                        ]
                    },
                    "ask_variables_on_launch": { "type": "boolean" },
                    "ask_inventory_on_launch": { "type": "boolean" },
                    "ask_limit_on_launch": { "type": "boolean" },
                    "ask_labels_on_launch": { "type": "boolean" },
                    "survey_enabled": { "type": "boolean" },
                    "survey_spec": { "type": "object" },
                    "simplified_workflow_nodes": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "required": ["identifier"],
                            "properties": {
                                "identifier": { "type": "string" },
                                "unified_job_template": { "type": "string" },
                                "organization": { "type": "string" },
                                "inventory": { "type": "string" },
                                "credentials": {
                                    "type": "array",
                                    "items": { "type": "string" }
                                },
                                "limit": { "type": "string" },
                                "job_tags": { "type": "string" },
                                "skip_tags": { "type": "string" },
                                "extra_data": { "type": "object" },
                                "success_nodes": {
                                    "type": "array",
                                    "items": { "type": "string" }
                                },
                                "failure_nodes": {
                                    "type": "array",
                                    "items": { "type": "string" }
                                },
                                "always_nodes": {
                                    "type": "array",
                                    "items": { "type": "string" }
                                },
                                "all_parents_must_converge": { "type": "boolean" }
                            },
                            "additionalProperties": false
                        }
                    },
                    "webhook_service": {
                        "type": "string",
                        "enum": ["github", "gitlab"]
                    },
                    "scm_branch": { "type": "string" }
                },
                "additionalProperties": false
            }
        }
    },
    "required": ["controller_workflows"],
    "additionalProperties": false
}
