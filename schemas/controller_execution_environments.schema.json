{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "AAP Controller Execution Environments Configuration",
    "type": "object",
    "properties": {
        "controller_execution_environments": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["name", "image"],
                "properties": {
                    "name": {
                        "type": "string",
                        "pattern": "^ee-[a-z0-9]+-[a-z0-9_]+-[a-z]+$",
                        "description": "EE name following naming convention: ee-<os>-<ansible_version>-<purpose>"
                    },
                    "description": { "type": "string" },
                    "image": {
                        "type": "string",
                        "description": "Full container image URL (registry/namespace/image:tag)"
                    },
                    "organization": {
                        "type": "string",
                        "pattern": "^org-[a-z0-9_]+$"
                    },
                    "pull": {
                        "type": "string",
                        "enum": ["always", "missing", "never"],
                        "description": "Image pull policy"
                    },
                    "credential": {
                        "type": "string",
                        "description": "Container registry credential name"
                    }
                },
                "additionalProperties": false
            }
        }
    },
    "required": ["controller_execution_environments"],
    "additionalProperties": false
}
