---
# Optional customer naming policy example.
#
# Copy this file to the root of casc-platform-control as naming-rules.yml only
# when naming validation is required. Omit resource types that should not have
# a format rule. Patterns validate resource identities in YAML, not filenames.
#
# aap_organizations:
#   pattern: "^WW .+ Automation$"
#   example: "WW Stores Automation"
#
# aap_teams:
#   pattern: "^.+ Automation$"
#   example: "Stores Automation"
