---
# Optional example only. Copy to casc-platform-control/naming-rules.yml and
# adapt it if type-prefixed resource identities are part of customer policy.
aap_organizations:
  pattern: "^org-[a-z0-9_]+$"
  example: "org-stores"
  description: "Optional Organization prefix profile"

aap_teams:
  pattern: "^team-[a-z0-9_]+$"
  example: "team-stores_automation"
  description: "Optional Team prefix profile"

controller_projects:
  pattern: "^prj-[a-z0-9_]+-[a-z0-9_]+(-[a-z0-9_]+)*$"
  example: "prj-stores-deploy"

controller_credentials:
  pattern: "^crd-[a-z0-9_]+(-[a-z0-9_]+)+$"
  example: "crd-stores-machine"

controller_inventories:
  pattern: "^inv-[a-z0-9_]+(-[a-z0-9_]+)+$"
  example: "inv-stores-dev"

controller_templates:
  pattern: "^jt-[a-z0-9_]+-[a-z0-9_]+(-[a-z0-9_]+)*$"
  example: "jt-stores-deploy"

controller_workflows:
  pattern: "^wfjt-[a-z0-9_]+-[a-z0-9_]+(-[a-z0-9_]+)*$"
  example: "wfjt-stores-release"
