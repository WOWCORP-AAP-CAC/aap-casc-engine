{
    "controller_credential_types": [
        {
            "name": "ctp-database_credentials",
            "description": "Custom credential type for database connections",
            "kind": "cloud",
            "inputs": {
                "fields": [
                    {"id": "db_hostname", "label": "Database Hostname", "type": "string"},
                    {"id": "db_port", "label": "Database Port", "type": "string"},
                    {"id": "db_name", "label": "Database Name", "type": "string"},
                    {"id": "db_username", "label": "Database Username", "type": "string"},
                    {"id": "db_password", "label": "Database Password", "type": "string", "secret": true}
                ],
                "required": ["db_hostname", "db_port", "db_name", "db_username", "db_password"]
            },
            "injectors": {
                "extra_vars": {
                    "db_hostname": "{{ '{{' }} db_hostname {{ '}}' }}",
                    "db_port": "{{ '{{' }} db_port {{ '}}' }}",
                    "db_name": "{{ '{{' }} db_name {{ '}}' }}",
                    "db_username": "{{ '{{' }} db_username {{ '}}' }}",
                    "db_password": "{{ '{{' }} db_password {{ '}}' }}"
                }
            }
        }
    ]
}
